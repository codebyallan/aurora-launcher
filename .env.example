# Aurora Launcher — environment variables
# Copy this file to .env and fill in the values as needed.

# URL of the SGDB proxy (Vercel Edge Function).
# Required for automatic cover art fetching.
# In production this is set as a GitHub Actions secret — not needed here.
# For local dev, point to your local proxy instance:
# AURORA_SGDB_PROXY=http://localhost:3000/api/sgdb